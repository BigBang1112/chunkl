{
  "name": "vscode-chunkl",
  "displayName": "ChunkL",
  "description": "Language support for ChunkL (.chunkl) files",
  "version": "0.1.0",
  "publisher": "bigbangstuff",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:chunkl"
  ],
  "contributes": {
    "languages": [
      {
        "id": "chunkl",
        "extensions": [
          ".chunkl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "chunkl",
        "scopeName": "source.chunkl",
        "path": "./syntaxes/chunkl.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.3.0"
  }
}
